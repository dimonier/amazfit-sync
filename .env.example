AMAZFIT_ACCESS_TOKEN=
AMAZFIT_REFRESH_TOKEN=

# Optional: if you already know app-level credentials, you can skip the access-token exchange.
AMAZFIT_APP_TOKEN=
AMAZFIT_USER_ID=
AMAZFIT_COUNTRY_CODE=US

# Optional endpoint overrides.
# AMAZFIT_TOKEN_REFRESH_URL=
# AMAZFIT_BEARER_API_BASE_URL=
# AMAZFIT_BEARER_PROBE_ENDPOINTS=/v1/health/overview,/v1/workouts
# AMAZFIT_ACCOUNT_BASE_URL=https://account.huami.com
# AMAZFIT_ZEPP_LOGIN_URL=https://api-mifit-us2.zepp.com/v2/client/login
# AMAZFIT_API_HOSTS=https://api-mifit.zepp.com,https://api-mifit-cn3.zepp.com,https://api-mifit-us2.zepp.com
# AMAZFIT_EXTRA_APP_ENDPOINTS=/v1/data/custom.json

# Runtime paths.
AMAZFIT_DATA_DIR=data
OBSIDIAN_EXPORT_DIR=exports/obsidian

# Optional defaults for CLI date range.
# AMAZFIT_FROM_DATE=2026-03-01
# AMAZFIT_TO_DATE=2026-03-15
