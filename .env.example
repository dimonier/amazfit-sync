# Permanent account identifiers.
AMAZFIT_USER_ID=
AMAZFIT_COUNTRY_CODE=US

# Login credentials for huami-token (refresh_tokens.py).
# Only needed if you use the mobile-logout fallback method.
AMAZFIT_EMAIL=
AMAZFIT_PASSWORD=

# Optional endpoint overrides.
# AMAZFIT_TOKEN_REFRESH_URL= (Zepp API v2 has no refresh endpoint; run `python extract_tokens_web.py` to refresh)
# AMAZFIT_AUTH_STATE_PATH=data/auth_state.json
# AMAZFIT_BEARER_API_BASE_URL=
# AMAZFIT_BEARER_PROBE_ENDPOINTS=/v1/health/overview,/v1/workouts
# AMAZFIT_ACCOUNT_BASE_URL=https://account.huami.com
# AMAZFIT_ZEPP_LOGIN_URL=https://api-mifit-us2.zepp.com/v2/client/login
# AMAZFIT_API_HOSTS=https://api-mifit.zepp.com,https://api-mifit-cn3.zepp.com,https://api-mifit-us2.zepp.com
# AMAZFIT_EXTRA_APP_ENDPOINTS=/v1/data/custom.json

# Runtime paths.
AMAZFIT_DATA_DIR=data
OBSIDIAN_EXPORT_DIR=exports/obsidian
# Absolute paths are supported too, for example:
# OBSIDIAN_EXPORT_DIR=D:/Obsidian-Dima/activity-reports

# Optional defaults for CLI date range.
# AMAZFIT_FROM_DATE=2026-03-01
# AMAZFIT_TO_DATE=2026-03-15

# Temporary tokens (access_token, refresh_token, app_token, device_id)
# are stored in data/auth_state.json.
# Run `python extract_tokens_web.py` to refresh app_token without mobile logout.
# Run `python refresh_tokens.py` as fallback (logs out mobile app).
